# ============================================================
# Hardyy Platform — Production Environment Variables Template
# Fill in production values securely in your hosting provider's
# secret management (Render / Railway / AWS / Docker secrets)
# ============================================================

# ---------- Server Configuration ----------
PORT=5000
NODE_ENV=production
SERVER_URL=https://api.yourdomain.com

# ---------- MongoDB (Production Atlas Cluster) ----------
MONGO_URI=

# ---------- JWT Security ----------
# Must be a cryptographically secure random string (minimum 64 characters)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ---------- Razorpay Payment Gateway (Live Mode Keys) ----------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---------- Twilio (WhatsApp & SMS Notifications) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=

# ---------- Nodemailer SMTP (Production Email Service e.g. SendGrid / AWS SES) ----------
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# ---------- Google OAuth 2.0 (Production Authorized Redirects) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- OpenAI (AI Chatbot & DALL-E 3 Image Generation) ----------
OPENAI_API_KEY=

# ---------- Google Maps API ----------
GOOGLE_MAPS_API_KEY=

# ---------- Frontend Client URL (CORS Production Allowed Origin) ----------
CLIENT_URL=https://emotion-delivery-platform.vercel.app

# ---------- Rescue Admin (Emergency Password Reset - Keep VERY secret) ----------
# Required: all three must be set in Render for /api/auth/rescue-admin to work
RESCUE_ADMIN_SECRET=
RESCUE_ADMIN_EMAIL=
RESCUE_ADMIN_PASSWORD=
