# ============================================================
# Hardyy Platform — Frontend Production Environment Variables
# Configure these variables in Vercel Project Settings -> Environment Variables
# ============================================================

# Production API Endpoint (Your hosted backend URL)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api

# Razorpay Live Key ID
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Google Maps Live API Key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
