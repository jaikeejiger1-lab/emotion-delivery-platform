# ============================================================
# .dockerignore — Files excluded from Docker container build
# ============================================================

# Dependencies & build cache
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.backup

# Local environment variables & secrets (CRITICAL for security)
.env
.env.*
!.env.example
!.env.production

# Version control & OS artifacts
.git
.gitignore
.DS_Store
Thumbs.db

# Documentation & testing scripts
*.md
check_users.js
seed.js
test/
tests/
coverage/
